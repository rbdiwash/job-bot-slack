# Adzuna API (free at https://developer.adzuna.com/signup)
ADZUNA_APP_ID=your_app_id
ADZUNA_APP_KEY=your_app_key

# JSearch / RapidAPI (Google Jobs, LinkedIn, Indeed, Seek - free 200 req/month)
# Subscribe at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
RAPIDAPI_KEY=your_rapidapi_key

# SerpAPI (Google Jobs - free 100 searches/month)
# Get key at https://serpapi.com
SERPAPI_KEY=your_serpapi_key

# Slack (create app at https://api.slack.com/apps, add chat:write scope)
SLACK_BOT_TOKEN=
SLACK_CHANNEL= all-job-search
SLACK_WEBHOOK_URL = 
SLACK_WEBHOOK_INDEED = 

SLACK_WEBHOOK_LINKEDIN = 

SLACK_WEBHOOK_SEEK = 

