# One webhook per source = one channel per source.
SLACK_WEBHOOK_LINKEDIN=https://hooks.slack.com/services/YOUR/LINKEDIN/WEBHOOK
SLACK_WEBHOOK_INDEED=https://hooks.slack.com/services/YOUR/INDEED/WEBHOOK
SLACK_WEBHOOK_GOOGLE=https://hooks.slack.com/services/YOUR/GOOGLE/WEBHOOK
SLACK_WEBHOOK_SEEK=https://hooks.slack.com/services/YOUR/SEEK/WEBHOOK

# LinkedIn jobs via RSS (no API key). Create feed at rss.app from LinkedIn job search URL.
# Use {keywords} and {location} in the URL to fill from job title + location.
LINKEDIN_RSS_URL=
